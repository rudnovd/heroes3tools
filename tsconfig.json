{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["ES2022", "DOM", "ScriptHost", "WebWorker"],
    "moduleResolution": "bundler",
    "paths": { "@/*": ["./src/*"] },
    "resolveJsonModule": true,
    "types": ["vite/client", "vite-plugin-pwa/client", "@intlify/unplugin-vue-i18n/messages"],
    "importHelpers": true,
    "noEmit": true,
    "removeComments": true,
    "sourceMap": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "references": [{ "path": "./tsconfig.node.json" }],
  "include": ["src/**/*.ts", "src/**/*.vue", "tests/**/*.ts", "tests/**/*.spec.ts"]
}
