{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "heroes3tools",
  "version": "2.9.0",
  "identifier": "com.rudnovd.heroes3tools",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm start",
    "beforeBuildCommand": "pnpm build:app",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "Heroes 3 Tools",
        "width": 1280,
        "height": 1024,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
